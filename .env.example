# Postgres (compose provisions the DB from these)
POSTGRES_USER=tips
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=tips
# Keep user/password/host in sync with the POSTGRES_* values above.
DATABASE_URL=postgresql://tips:change-me-in-prod@postgres:5432/tips?schema=public

# Auth: secret used to sign/verify access-token JWTs. The API refuses to boot
# without it (main.ts). Refresh tokens are random opaque strings (hashed in DB),
# so they need no separate secret.
JWT_SECRET=change-me-in-prod

# Payment webhook credentials (billing.module.ts uses getOrThrow — the API will
# not start if these are unset). LastLink now; Payt when migrating later.
LASTLINK_WEBHOOK_SECRET=change-me-lastlink
PAYT_WEBHOOK_TOKEN=change-me-payt

# IA Tipster analysis engine. With a DeepSeek key the analyses are written by
# the model (OpenAI-compatible API); without it the app uses a deterministic
# template (dev/tests). Get a key at https://platform.deepseek.com.
DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Football data (team catalog sync). Key from https://dashboard.api-football.com
# — free tier: 100 req/day, seasons 2022–2024 only. Optional: without it the
# admin "sync teams" action returns 503 and everything else keeps working.
API_FOOTBALL_KEY=
# API_FOOTBALL_URL=v3.football.api-sports.io

# Sportsbook fixtures feed (Esportiva). Defaults target the public Altenar
# widget the Esportiva site uses today; when the official Esportiva endpoint is
# provided, point these at it (or add a provider and rebind SportsFeedModule).
# {id} in the URL template is replaced by the provider event id.
# ALTENAR_BASE_URL=https://sb2frontend-altenar2.biahosted.com/api/Widget
# ALTENAR_INTEGRATION=esportiva
# ESPORTIVA_EVENT_URL_TEMPLATE=https://esportiva.bet.br/sports/?bt-path=%2Fevent%2F{id}

# Web build-time config (optional; safe defaults exist). VITE_API_URL defaults to
# /api (proxied by nginx); VITE_CHECKOUT_URL is the hosted LastLink checkout link.
# Each paid plan is its own LastLink product — point the per-plan URLs at their
# hosted checkouts and register the matching Product rows (grantType=plan,
# grantPlanKey=premium|diamante, grantPeriodDays omitted = lifetime/VIDA).
# VITE_API_URL=/api
# VITE_CHECKOUT_URL=https://lastlink.com/your-product
# VITE_CHECKOUT_URL_PREMIUM=https://lastlink.com/p/premium-product
# VITE_CHECKOUT_URL_DIAMANTE=https://lastlink.com/p/diamante-product
# VITE_TELEGRAM_URL=https://t.me/+arena_fc
# IA credit packs ("Comprar créditos IA" modal). Optional per-pack checkout
# URLs; without them the generic checkout is used with a ?produto= tag. The
# suffix is the pack id upper-cased with dashes as underscores. Register the
# matching Product rows (see api/prisma/seeds/products.seed.ts): credits packs
# grant 6/9 credits; the unlimited passes grant ia_unlimited for 30/90 days.
# VITE_CHECKOUT_URL_PREMIER_6_CREDITOS_IA=https://lastlink.com/p/6-creditos
# VITE_CHECKOUT_URL_PREMIER_9_CREDITOS_IA=https://lastlink.com/p/9-creditos
# VITE_CHECKOUT_URL_PREMIER_ILIMITADO_1_MES=https://lastlink.com/p/ilimitado-1m
# VITE_CHECKOUT_URL_PREMIER_ILIMITADO_3_MESES=https://lastlink.com/p/ilimitado-3m

NODE_ENV=development
