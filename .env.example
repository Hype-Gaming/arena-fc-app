# Postgres (compose provisions the DB from these)
POSTGRES_USER=tips
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=tips
# Keep user/password/host in sync with the POSTGRES_* values above.
DATABASE_URL=postgresql://tips:change-me-in-prod@postgres:5432/tips?schema=public

# Auth: secret used to sign/verify access-token JWTs. The API refuses to boot
# without it (main.ts). Refresh tokens are random opaque strings (hashed in DB),
# so they need no separate secret.
JWT_SECRET=change-me-in-prod

# Payment webhook credentials (billing.module.ts uses getOrThrow — the API will
# not start if these are unset). LastLink now; Payt when migrating later.
LASTLINK_WEBHOOK_SECRET=change-me-lastlink
PAYT_WEBHOOK_TOKEN=change-me-payt

# Football data (team catalog sync). Key from https://dashboard.api-football.com
# — free tier: 100 req/day, seasons 2022–2024 only. Optional: without it the
# admin "sync teams" action returns 503 and everything else keeps working.
API_FOOTBALL_KEY=
# API_FOOTBALL_URL=v3.football.api-sports.io

# Web build-time config (optional; safe defaults exist). VITE_API_URL defaults to
# /api (proxied by nginx); VITE_CHECKOUT_URL is the hosted LastLink checkout link.
# VITE_API_URL=/api
# VITE_CHECKOUT_URL=https://lastlink.com/your-product

NODE_ENV=development
