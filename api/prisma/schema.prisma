generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  user
  admin
}

enum PlanKey {
  free
  premium
  diamante
}

enum SubscriptionStatus {
  active
  canceled
  expired
}

enum CreditTransactionType {
  purchase
  grant
  unlock
  refund
}

enum MatchStatus {
  scheduled
  live
  finished
}

enum EntradaStatus {
  pending
  green
  red
}

enum GrantType {
  credits
  plan
  category_access
  // Time-boxed "acesso ilimitado" pass: analyses stop consuming credits for
  // grantPeriodDays. Extends User.iaUnlimitedUntil instead of moving credits.
  ia_unlimited
}

enum ChatRole {
  user
  assistant
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  level     Int      @default(1)
  xp        Int      @default(0)
  role      Role     @default(user)
  // Profile identity (self-chosen). nickname is not enforced unique — display
  // handles may collide; avatarKey selects one of the preset emblem avatars.
  nickname  String?
  avatarKey String?
  // Daily-login streak (Phase 3). currentLoginStreak resets to 1 on a missed
  // day; bestLoginStreak is the all-time high; lastLoginAt gates one count/day.
  currentLoginStreak Int       @default(0)
  bestLoginStreak    Int       @default(0)
  lastLoginAt        DateTime?
  // While set and in the future, IA Tipster analyses don't consume credits
  // ("acesso ilimitado" pass). Extended by ia_unlimited product grants.
  iaUnlimitedUntil DateTime?

  authCodes        AuthCode[]
  refreshTokens    RefreshToken[]
  subscriptions    Subscription[]
  creditTxns       CreditTransaction[]
  entradaUnlocks   EntradaUnlock[]
  userAchievements UserAchievement[]
  chatSessions     ChatSession[]
  telegramUnlock   TelegramUnlock?
  categoryAccesses UserCategoryAccess[]
}

model AuthCode {
  id        String    @id @default(cuid())
  userId    String
  code      String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Plan {
  key            PlanKey @id
  name           String
  priceLabel     String
  monthlyCredits Int     @default(0)
  // Access ordering: free=0 < premium=1 < diamante=2. A plan unlocks every
  // bilhete category whose minimum rank is <= its own.
  rank           Int     @default(0)

  subscriptions Subscription[]
}

model Subscription {
  id               String             @id @default(cuid())
  userId           String
  planKey          PlanKey
  status           SubscriptionStatus @default(active)
  provider         String
  externalId       String?
  currentPeriodEnd DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planKey], references: [key])

  @@unique([userId])
  @@index([userId])
}

model CreditTransaction {
  id           String                @id @default(cuid())
  seq          BigInt                @default(autoincrement()) @unique
  userId       String
  type         CreditTransactionType
  amount       Int
  balanceAfter Int
  refType      String?
  refId        String?
  createdAt    DateTime              @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Category {
  id   String @id @default(cuid())
  name String
  slug String @unique
  icon String?

  matches Match[]
}

model Match {
  categoryId  String
  id          String      @id @default(cuid())
  homeTeam    String
  awayTeam    String
  competition String
  startsAt    DateTime
  status      MatchStatus @default(scheduled)
  createdAt   DateTime    @default(now())

  category Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  entradas Entrada[]

  @@index([categoryId])
}

model Entrada {
  id             String        @id @default(cuid())
  matchId        String
  market         String
  selection      String
  odd            Decimal       @db.Decimal(6, 2)
  justification  String
  costInCredits  Int
  status         EntradaStatus @default(pending)
  publishedAt    DateTime?
  createdAt      DateTime      @default(now())

  match   Match           @relation(fields: [matchId], references: [id], onDelete: Cascade)
  unlocks EntradaUnlock[]

  @@index([matchId])
}

model EntradaUnlock {
  id         String   @id @default(cuid())
  userId     String
  entradaId  String
  unlockedAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  entrada Entrada @relation(fields: [entradaId], references: [id], onDelete: Cascade)

  @@unique([userId, entradaId])
  @@index([userId])
}

model Product {
  id                String    @id @default(cuid())
  provider          String
  externalProductId String
  grantType         GrantType
  grantCredits      Int?
  grantPlanKey      PlanKey?
  grantCategory     BilheteCategoria?
  // Subscription length granted by a 'plan' product, in days.
  // null = lifetime ("VIDA" checkout products — no expiry).
  grantPeriodDays   Int?
  active            Boolean   @default(true)

  @@unique([provider, externalProductId])
}

model WebhookEvent {
  id          String    @id @default(cuid())
  provider    String
  externalId  String    @unique
  type        String
  payload     Json
  processedAt DateTime?
  createdAt   DateTime  @default(now())
}

model Achievement {
  key         String @id
  name        String
  description String
  icon        String?
  criteria    Json
  // Grouping for the Perfil screen (permanent | streak | daily), persisted so
  // the front no longer infers it from key/icon. rewardXp is the bonus granted
  // when the achievement unlocks.
  category    String @default("permanent")
  rewardXp    Int    @default(0)

  userAchievements UserAchievement[]
}

model UserAchievement {
  id             String   @id @default(cuid())
  userId         String
  achievementKey String
  unlockedAt     DateTime @default(now())
  progress       Int      @default(0)

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementKey], references: [key], onDelete: Cascade)

  @@unique([userId, achievementKey])
  @@index([userId])
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      ChatRole
  content   String
  entradaId String?
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

enum BilheteCategoria {
  safes
  pro
  ultra
  alavancagem
  multiplas
  secundario
  ligas
}

enum BilheteResultado {
  pending
  green
  red
}

model Bilhete {
  id          String           @id @default(cuid())
  titulo      String           @default("Bilhete Especial")
  categoria   BilheteCategoria
  // The betting market this tip is on. `mercado` is the market slug/name
  // ("1x2", "over_under", "btts", …); `selecao` is the picked outcome label
  // as the book shows it ("Mais de 2.5", "Sim", "Botafogo"); `linha` is the
  // goal/handicap line when the market carries one (Over/Under). Legacy rows
  // predate markets and keep null → they render as the old "Bilhete Especial".
  mercado     String?
  selecao     String?
  linha       Decimal?         @db.Decimal(6, 2)
  homeTeam    String
  awayTeam    String
  homeColor   String? // crest accent hex fallback when there is no logo
  awayColor   String?
  homeLogo    String? // snapshot of the catalog logo URL at creation time
  awayLogo    String?
  competition String?
  startsAt    DateTime
  validUntil  DateTime?
  odd         Decimal          @db.Decimal(6, 2)
  resultado   BilheteResultado @default(pending)
  publishedAt DateTime?
  createdAt   DateTime         @default(now())
  // Deep link that opens this fixture on the sportsbook (Esportiva/Altenar),
  // snapshotted at creation. The "Adicionar" button sends the user straight to
  // the event so they place the bet on their own account.
  eventDeepLink   String?
  eventExternalId String?

  @@index([categoria, startsAt])
  @@index([validUntil])
}

model UserCategoryAccess {
  id          String           @id @default(cuid())
  userId      String
  categoria   BilheteCategoria
  provider    String
  externalId  String?
  purchasedAt DateTime         @default(now())
  expiresAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, categoria])
  @@index([userId])
}

// A fixture pulled from the sportsbook feed (Altenar/Esportiva today; the
// official endpoint later — same normalized shape, swapped behind a provider).
// Cached so the admin picks a real event (teams, kickoff, 1X2 odds, deep link)
// instead of typing it.
model SportEvent {
  id          String   @id @default(cuid())
  provider    String // "altenar" now; "esportiva" when the official feed lands
  externalId  String // provider event id
  homeTeam    String
  awayTeam    String
  competition String?
  // ISO-3166 alpha-3 of the competition's country (null for international),
  // snapshotted so the crest fallback can break same-name club collisions.
  countryIso  String?
  startsAt    DateTime
  oddHome     Decimal? @db.Decimal(6, 2)
  oddDraw     Decimal? @db.Decimal(6, 2)
  oddAway     Decimal? @db.Decimal(6, 2)
  // Core markets snapshot (1X2, Over/Under, Double chance, DNB, BTTS) as a
  // NormalizedMarket[] JSON blob, so the admin can build a bilhete on any
  // offered market/selection without re-fetching the feed. Null on legacy rows.
  markets     Json?
  deepLink    String
  syncedAt    DateTime @default(now())
  // Live score capture (populated by the settle poller off GetLiveEvents while
  // the match is in play; the feed drops finished matches, so we freeze the last
  // seen score). finishedAt is set once the match window elapses, marking the
  // score final and ready to grade bilhetes against.
  homeScore   Int?
  awayScore   Int?
  scoreSeenAt DateTime?
  finishedAt  DateTime?

  @@unique([provider, externalId])
  @@index([startsAt])
}

// Team catalog cached from the external football API (one sync request per
// league/season; the admin picks teams from here to get name+logo for free).
model Team {
  id         String   @id @default(cuid())
  externalId Int      @unique // API-Football team id
  name       String
  code       String? // 3-letter short code when the provider has one
  country    String?
  logoUrl    String
  leagueName String?
  season     Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([name])
}

model TutorialStep {
  id        String   @id @default(cuid())
  version   Int
  order     Int
  title     String
  body      String
  imageUrl  String?
  createdAt DateTime @default(now())

  @@unique([version, order])
}

model TelegramUnlock {
  id         String    @id @default(cuid())
  userId     String    @unique
  clickedAt  DateTime  @default(now())
  unlockedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
