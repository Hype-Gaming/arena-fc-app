# Production environment template.
# Copy this file to .env.production on the VPS and fill real secrets there.

NODE_ENV=production

# External Postgres, for example Neon.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Kept only to satisfy the base compose interpolation. The local Postgres
# service is disabled in production by docker-compose.prod.yml.
POSTGRES_USER=tips
POSTGRES_PASSWORD=unused-in-production
POSTGRES_DB=tips

JWT_SECRET=change-me
ADMIN_EMAILS=
LASTLINK_WEBHOOK_SECRET=change-me
PAYT_WEBHOOK_TOKEN=change-me

API_FOOTBALL_KEY=
ALLOW_DEV_LOGIN=false
VITE_API_URL=/api
